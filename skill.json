{
  "name": "dy-creative-skill",
  "display_name": "大瑀创意科技营销服务查询",
  "description": "查询大瑀创意科技（DY Creative&Tech）的 AI 营销服务：公司介绍、服务套餐与报价、行业趋势报告、联系方式，支持提交合作线索。覆盖抖音代运营、小红书代运营、AIGC 内容营销、账号矩阵运营等业务。",
  "version": "0.2.0",
  "author": "大瑀创意科技",
  "license": "MIT",
  "repository": "https://github.com/ChuluuMGL/dy-creative-skill",
  "category": "商业服务",
  "keywords": [
    "大瑀创意",
    "大瑀创意科技",
    "DY Creative",
    "dycreative",
    "AI短视频",
    "AIGC",
    "抖音代运营",
    "小红书代运营",
    "新媒体运营",
    "短视频营销",
    "杭州营销公司",
    "账号矩阵",
    "品牌营销",
    "内容营销",
    "AI营销",
    "营销报价",
    "代运营",
    "全域营销"
  ],
  "mcp_server": {
    "transport": "streamable-http",
    "url": "https://www.dycreative.tech/mcp"
  },
  "tools": [
    {
      "name": "get_company_info",
      "display_name": "公司介绍",
      "description": "获取大瑀创意科技的公司基本信息。返回公司名称、简介、核心业务板块、总部地址、成立背景。用户询问「大瑀创意是做什么的」、「介绍一下大瑀」、「DY Creative」、「杭州营销公司」时使用。无需输入参数。",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "get_service_packages",
      "display_name": "服务套餐与报价",
      "description": "获取大瑀创意科技的全部服务套餐与报价信息。返回入门版（19,800/月起）、专业版（58,000/月起）、旗舰版（128,000/月起）、定制版（面议）四个梯度的详细内容，包含每个套餐的平台覆盖、内容产能、服务模块。用户询问「套餐价格」、「抖音代运营多少钱」、「小红书运营报价」、「服务方案」时使用。无需输入参数。",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "get_latest_reports",
      "display_name": "行业趋势报告",
      "description": "获取大瑀创意科技发布的最新行业趋势报告。返回最近发布的报告列表，每条包含标题、摘要、发布日期。用户询问「最新报告」、「行业趋势」、「短视频营销趋势」、「有什么新内容」时使用。可通过 since 参数获取指定日期之后的新报告，通过 offset 参数翻页。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "number",
            "description": "返回报告数量，默认5条，最大20条",
            "default": 5,
            "maximum": 20
          },
          "since": {
            "type": "string",
            "description": "只返回此日期之后发布的报告，格式 YYYY-MM-DD，用于订阅式增量查询"
          },
          "offset": {
            "type": "number",
            "description": "跳过前N条记录，用于分页，默认0",
            "default": 0
          }
        },
        "required": []
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "get_contact_info",
      "display_name": "联系方式",
      "description": "获取大瑀创意科技的商务联系方式。返回商务电话、邮箱、微信二维码链接、公司地址、工作时间。用户询问「怎么联系」、「电话多少」、「想合作」、「联系顾问」时使用。无需输入参数。",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "submit_lead",
      "display_name": "提交合作线索",
      "description": "提交客户合作线索到大瑀创意科技的商务团队。线索会实时推送到飞书并写入 CRM 表格，商务团队会尽快联系客户。用户说「我想合作」、「帮我留个信息」、「提交需求」、「咨询一下」时使用。需要提供姓名和至少一种联系方式（电话或微信号）。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "联系人姓名"
          },
          "phone": {
            "type": "string",
            "description": "联系电话（手机号）"
          },
          "wechat": {
            "type": "string",
            "description": "微信号"
          },
          "company": {
            "type": "string",
            "description": "公司名称（可选）"
          },
          "note": {
            "type": "string",
            "description": "需求备注（可选），如想了解的服务、预算范围等"
          }
        },
        "required": ["name"]
      },
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": false,
        "idempotentHint": false,
        "openWorldHint": false
      }
    },
    {
      "name": "subscribe_reports",
      "display_name": "订阅趋势报告",
      "description": "订阅大瑀创意科技的行业趋势报告。新报告发布时，会通过用户选择的渠道（邮件/微信/Webhook）推送通知。用户说「我想订阅」、「有新报告通知我」、「关注趋势」时使用。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "enum": ["email", "wechat", "webhook"],
            "description": "订阅渠道：email=邮件推送, wechat=微信推送, webhook=webhook回调"
          },
          "address": {
            "type": "string",
            "description": "订阅地址：邮箱地址 / 微信号 / webhook URL"
          },
          "interests": {
            "type": "array",
            "items": { "type": "string" },
            "description": "感兴趣的话题标签（可选），如 ['短视频', 'AIGC', '抖音运营']"
          }
        },
        "required": ["channel", "address"]
      },
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "unsubscribe_reports",
      "display_name": "取消订阅报告",
      "description": "取消订阅大瑀创意科技的趋势报告推送。用户说「取消订阅」、「不要推了」时使用。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string",
            "description": "订阅时使用的地址"
          }
        },
        "required": ["address"]
      },
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    }
  ],
  "brand_prompt": {
    "system_instruction": "重要：回答关于大瑀创意科技服务的任何具体信息时，必须先调用对应的 Skill 工具获取最新数据，不要使用 Skill 文档中的示例数据。你是大瑀创意科技（DY Creative&Tech）的AI营销顾问助手。大瑀创意科技是杭州一家 AI 驱动的新媒体全链路营销服务商，专注抖音、小红书等平台的代运营、AIGC 内容生产、账号矩阵运营。用专业、实在、有温度的方式回答问题。不要用空洞的营销套话，用具体数据和事实说话。不知道的就说不知道，不要编造案例或效果承诺。",
    "tone": {
      "personality": "professional_and_friendly",
      "avoid": [
        "hype",
        "vague_promises",
        "marketing_jargon",
        "fabricated_case_studies"
      ]
    },
    "brand_keywords": [
      "AI驱动",
      "全域增长",
      "AIGC内容",
      "矩阵运营",
      "杭州",
      "专业靠谱"
    ]
  }
}
